TELEGRAM_BOT_TOKEN=YOUR_TOKEN
DISCORD_BOT_TOKEN=YOUR_TOKEN

# Optional bridge/runtime controls
# DISCORD_ADMIN_ROLE_IDS=1234567890,0987654321
# DISCORD_TRUSTED_USER_IDS=12345,67890
# TELEGRAM_TRUSTED_USER_IDS=12345,67890
# DUPLICATE_WINDOW_SECONDS=600
# QUEUE_POLL_MILLISECONDS=250
# QUEUE_PROCESSING_LEASE_SECONDS=30
# DELIVERY_MAX_RETRIES=5
# DELIVERY_RETRY_BASE_SECONDS=2

# Security Rate Limiting
# RATE_LIMIT_SOURCE_MAX=30
# RATE_LIMIT_SOURCE_WINDOW_SECONDS=60
# RATE_LIMIT_DEST_MAX=60
# RATE_LIMIT_DEST_WINDOW_SECONDS=60

# Optional observability controls
# OBSERVABILITY_HTTP_ENABLED=true
# OBSERVABILITY_HTTP_ADDR=:8081
# READY_CONSUMER_STALE_SECONDS=30
# ALERT_EVALUATION_INTERVAL_SECONDS=30
# ALERT_FAILURE_RATE_THRESHOLD=0.25
# ALERT_FAILURE_MIN_SAMPLE_SIZE=10
# ALERT_QUEUE_DEPTH_THRESHOLD=500
# ALERT_RETRY_DEPTH_THRESHOLD=100
# ALERT_RECONNECT_STREAK_THRESHOLD=5

# Optional AI moderation layer
# AI_MODERATION_ENABLED=false
# AI_MODERATION_MIN_SCORE=0.70
# AI_MODERATION_KEYWORDS=

# Optional admin panel
# ADMIN_HTTP_ENABLED=false
# ADMIN_HTTP_ADDR=:8091
# ADMIN_HTTP_TOKEN=change_me
# ADMIN_HTTP_DEFAULT_LIMIT=100